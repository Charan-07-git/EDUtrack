generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
}

enum SessionStatus {
  SCHEDULED
  ACTIVE
  ENDED
  QR_ACTIVE
  QR_EXPIRED
}

model User {
  id             String        @id @default(cuid())
  name           String
  email          String        @unique
  password       String
  role           Role
  department     String?
  semester       Int?
  year           Int?
  selectedSubject String?
  designation    String?
  facultyCode    String?
  rollNumber     String?
  photoUrl       String?
  faceDescriptor Json?
  faceRegistered Boolean  @default(false)
  createdAt      DateTime      @default(now())

  teacherClasses Class[]       @relation("TeacherClasses")
  attendances    Attendance[]
  announcements  Announcement[]
}
model Class {
  id        String        @id @default(cuid())
  subject   String
  code      String
  department String
  semester  Int
  year      Int
  teacherId String
  teacher   User          @relation("TeacherClasses", fields: [teacherId], references: [id])
  timetable Timetable[]
  sessions  Session[]
  announcements Announcement[]
}

model Timetable {
  id        String   @id @default(cuid())
  classId   String
  dayOfWeek Int
  startTime String
  endTime   String
  room      String
  class     Class    @relation(fields: [classId], references: [id])
}

model Session {
  id          String        @id @default(cuid())
  classId     String
  teacherId   String
  status      SessionStatus @default(SCHEDULED)
  startTime   DateTime?
  endTime     DateTime?
  qrToken     String?
  qrExpiresAt DateTime?
  teacherLat  Float?
  teacherLng  Float?
  createdAt   DateTime      @default(now())
  class       Class         @relation(fields: [classId], references: [id])
  attendances Attendance[]
}

model Attendance {
  id               String    @id @default(cuid())
  sessionId        String
  studentId        String
  markedAt         DateTime  @default(now())
  faceVerified     Boolean
  locationVerified Boolean
  facePhotoUrl     String?

  session          Session   @relation(fields: [sessionId], references: [id])
  student          User      @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
}

model Goal {
  id             String  @id @default(cuid())
  studentId      String
  subject        String
  currentPercent Float
  targetPercent  Float   @default(75)
  classesNeeded  Int
}

model Announcement {
  id        String   @id @default(cuid())
  classId   String
  teacherId String
  title     String
  content   String
  createdAt DateTime @default(now())
  expiresAt DateTime?

  class     Class    @relation(fields: [classId], references: [id])
  teacher   User     @relation(fields: [teacherId], references: [id])
}
